{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "specifyjs",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "specifyjs": ["../core/src/index.ts"],
      "specifyjs/hooks": ["../core/src/hooks/index.ts"],
      "specifyjs/dom": ["../core/src/dom/index.ts"]
    }
  },
  "include": ["src"]
}
